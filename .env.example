# Azure Storage Configuration
# Copy this file to .env and fill in your actual tokens

# Cloud Storage Mode (set to True for production)
USE_CLOUD_STORAGE=False

# Flask Configuration
DEBUG=True
PORT=5000
SECRET_KEY=your-secret-key-here-change-in-production

# Azure Storage Account
AZURE_STORAGE_ACCOUNT_NAME=pacifictubestorage

# Blob Storage SAS Token (for videos)
AZURE_STORAGE_SAS_TOKEN=se=2027-03-19T23%3A59%3A59Z&sp=rl&spr=https&sv=2026-02-06&sr=c&sig=YOUR_BLOB_SAS_TOKEN

# Table Storage SAS Token (for view tracking)
AZURE_TABLE_SAS_TOKEN=se=2027-03-19T23%3A59%3A59Z&sp=raud&spr=https&sv=2019-02-02&tn=views&sig=YOUR_TABLE_SAS_TOKEN

# ===== Entra ID (Azure AD) Authentication =====
# Set to True to enable Entra ID authentication (requires credentials from ICT team)
ENABLE_ENTRA_ID=False

# Entra ID Configuration (Get these from ICT team after approval)
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=your-client-secret-from-ict-team
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_AUTHORITY=https://login.microsoftonline.com/YOUR_TENANT_ID
ENTRA_REDIRECT_PATH=/auth/callback

# Allowed user groups/roles (optional - leave empty to allow all authenticated users)
# Format: group1,group2,group3
ENTRA_ALLOWED_GROUPS=

# Session configuration (in-memory cache - faster & safer than filesystem)
SESSION_TYPE=cachelib
SESSION_PERMANENT=False
PERMANENT_SESSION_LIFETIME=3600
