# Azure Storage Configuration
# Copy this file to .env and fill in your actual tokens

# Cloud Storage Mode (set to True for production)
USE_CLOUD_STORAGE=False

# Flask Configuration
DEBUG=True
PORT=5000

# Azure Storage Account
AZURE_STORAGE_ACCOUNT_NAME=pacifictubestorage

# Blob Storage SAS Token (for videos)
AZURE_STORAGE_SAS_TOKEN=se=2027-03-19T23%3A59%3A59Z&sp=rl&spr=https&sv=2026-02-06&sr=c&sig=YOUR_BLOB_SAS_TOKEN

# Table Storage SAS Token (for view tracking)
AZURE_TABLE_SAS_TOKEN=se=2027-03-19T23%3A59%3A59Z&sp=raud&spr=https&sv=2019-02-02&tn=views&sig=YOUR_TABLE_SAS_TOKEN
